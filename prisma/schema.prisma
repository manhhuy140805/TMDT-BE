// SCHEMA MOI - Refactored: Tat ca FK nghiep vu dung TaiKhoanID truc tiep
// Bang NguoiThue, Freelancer, DonViGiamSat chi la profile bo sung

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum GioiTinh {
  Nam
  Nu
  Khac
}

enum VaiTroTaiKhoan {
  KhachVangLai
  NguoiThue
  Freelancer
  DonViGiamSat
  Admin
}

enum TrangThaiTaiKhoan {
  HoatDong
  BiKhoa
  ChoDuyet
  DaBi
}

enum TrangThaiDonViGiamSat {
  HoatDong
  TamNghi
  BiKhoa
  ChoDuyet
}

enum TrangThaiYeuCau {
  DangNhanHoSo
  DaDong
  DaChot
  DaHuy
}

enum TrangThaiBaoGia {
  DaGui
  DuocChon
  TuChoi
  HetHan
}

enum TrangThaiCongViec {
  MoiTao
  DangThucHien
  HoanThanh
  DaHuy
  TranhChap
}

enum TrangThaiGiamSatCongViec {
  KhongCo
  ChoDuyet
  DangGiamSat
  HoanThanh
  TuChoi
}

enum TrangThaiYeuCauGiamSat {
  ChoDuyet
  DaChapNhan
  TuChoi
  HoanThanh
}

enum TrangThaiXacNhanTienDo {
  ChuaXacNhan
  DaXacNhan
  TuChoi
}

enum TrangThaiTranhChap {
  MoiMo
  DangXuLy
  DaKetLuan
  DaDong
}

enum TrangThaiYeuCauHoanTien {
  ChoFreelancerDuyet
  DaDongY
  DaTuChoi
}

enum LoaiBangChung {
  TinNhan
  File
  HinhAnh
  GhiChu
  KhacP
}

enum KetQuaTranhChap {
  TiepTuc
  HoanTienNguoiThue
  HuyHopDong
  PhanChia
}

enum BenChiuPhiKetLuan {
  NguoiThue
  Freelancer
  ChiaSe
  HeThong
}

enum LoaiThanhToan {
  DatCoc
  ThanhToanCuoi
  HoanTien
  PhiGiamSat
  PhiHeThong
}

enum PhuongThucThanhToan {
  ChuyenKhoan
  ThanhToanQuaMang
  Vi
  TienMat
}

enum TrangThaiThanhToan {
  ChoXuLy
  ThanhCong
  ThatBai
  DaHoan
}

enum TrangThaiCuocHoiThoai {
  DangMo
  DaDong
}

enum LoaiTinNhan {
  VanBan
  File
  HinhAnh
}

enum LoaiDanhGia {
  NguoiThue_DanhGia_Freelancer
  Freelancer_DanhGia_NguoiThue
  NguoiThue_DanhGia_GiamSat
  Freelancer_DanhGia_GiamSat
  GiamSat_DanhGia_Freelancer
  GiamSat_DanhGia_NguoiThue
}

enum LoaiThongBao {
  HeThong
  YeuCau
  BaoGia
  CongViec
  TranhChap
  GiamSat
  ThanhToan
  DanhGia
}

enum TrangThaiBaoCao {
  ChoXuLy
  DangXuLy
  DaXuLy
  HuyBo
}

enum LoaiGiamKhuyenMai {
  PhanTram
  SoTienCo
}

enum TrangThaiKhuyenMai {
  HoatDong
  HetHan
  ThuHoi
}

// ============ CORE: TAI KHOAN ============

model TaiKhoan {
  TaiKhoanID  Int               @id @default(autoincrement())
  TenDangNhap String            @unique @db.VarChar(50)
  MatKhau     String            @db.VarChar(255)
  Email       String            @unique @db.VarChar(100)
  HoTen       String            @db.VarChar(100)
  SoDienThoai String?           @db.VarChar(15)
  GioiTinh    GioiTinh?
  DiaChi      String?           @db.VarChar(255)
  VaiTro      VaiTroTaiKhoan    @default(KhachVangLai)
  TrangThai   TrangThaiTaiKhoan @default(HoatDong)
  NgayTao     DateTime          @default(now()) @db.Timestamp(3)
  NgayCapNhat DateTime          @updatedAt @db.Timestamp(3)

  // Profile bo sung (1-1)
  NguoiThue    NguoiThue?
  Freelancer   Freelancer?
  DonViGiamSat DonViGiamSat?

  // FK nghiep vu - nguoi tao yeu cau
  YeuCaus                   YeuCau[]             @relation("YeuCauNguoiTao")
  // FK nghiep vu - giam sat duoc chon cho yeu cau
  YeuCausGiamSat            YeuCau[]             @relation("YeuCauGiamSat")
  // FK nghiep vu - bao gia
  BaoGias                   BaoGia[]
  // FK nghiep vu - hop dong
  CongViecsNguoiThue        CongViec[]           @relation("CongViecNguoiThue")
  CongViecsFreelancer       CongViec[]           @relation("CongViecFreelancer")
  CongViecsGiamSat          CongViec[]           @relation("CongViecGiamSat")
  // Tien do
  TienDos                   TienDo[]
  // Thanh toan
  ThanhToans                ThanhToan[]
  // Chat
  CuocHoiThoais1            CuocHoiThoai[]       @relation("ChatThanhVien1")
  CuocHoiThoais2            CuocHoiThoai[]       @relation("ChatThanhVien2")
  TinNhans                  TinNhan[]
  // Tranh chap
  TranhChaps                TranhChap[]
  BangChungs                BangChungTranhChap[]
  YeuCauHoanTiensNguoiThue  YeuCauHoanTien[]     @relation("HoanTienNguoiThue")
  YeuCauHoanTiensFreelancer YeuCauHoanTien[]     @relation("HoanTienFreelancer")
  BangChungHoanTiens        BangChungHoanTien[]
  BangChungKetLuans         BangChungKetLuan[]
  // Danh gia
  DanhGiasGui               DanhGia[]            @relation("DanhGiaNguoiGui")
  DanhGiasNhan              DanhGia[]            @relation("DanhGiaNguoiNhan")
  // Thong bao
  ThongBaos                 ThongBao[]
  // Bao cao
  BaoCaosGui                BaoCao[]             @relation("BaoCaoNguoiGui")
  BaoCaosNhan               BaoCao[]             @relation("BaoCaoNguoiNhan")
  BaoCaosAdmin              BaoCao[]             @relation("BaoCaoAdmin")
  // Ky nang freelancer
  FreelancerKyNangs         FreelancerKyNang[]
  // Yeu cau giam sat
  YeuCauGiamSatsNguoiThue   YeuCauGiamSat[]      @relation("YCGSNguoiThue")
  YeuCauGiamSatsFreelancer  YeuCauGiamSat[]      @relation("YCGSFreelancer")
  YeuCauGiamSatsGiamSat     YeuCauGiamSat[]      @relation("YCGSGiamSat")
}

// ============ PROFILE BO SUNG ============

model NguoiThue {
  NguoiThueID   Int     @id @default(autoincrement())
  TaiKhoanID    Int     @unique
  CongTy        String? @db.VarChar(150)
  MoTa          String? @db.Text
  DiemTinCay    Decimal @default(0.00) @db.Decimal(3, 2)
  TongYeuCau    Int     @default(0)
  TyLeHoanThanh Decimal @default(0.00) @db.Decimal(5, 2)

  TaiKhoan TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID], onDelete: Cascade)
}

model Freelancer {
  FreelancerID  Int     @id @default(autoincrement())
  TaiKhoanID    Int     @unique
  KinhNghiem    Int     @default(0)
  ChuyenGia     String? @db.VarChar(150)
  KyNang        String? @db.Text
  XepHang       Decimal @default(0.00) @db.Decimal(3, 2)
  SoDu          Decimal @default(0.00) @db.Decimal(15, 2)
  XacThucEmail  Boolean @default(false)
  XacThucSDT    Boolean @default(false)
  TongCongViec  Int     @default(0)
  TyLeHoanThanh Decimal @default(0.00) @db.Decimal(5, 2)

  TaiKhoan TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID], onDelete: Cascade)
}

model DonViGiamSat {
  GiamSatID      Int                   @id @default(autoincrement())
  TaiKhoanID     Int                   @unique
  TenDonVi       String                @db.VarChar(150)
  MoTa           String?               @db.Text
  NangLuc        String?               @db.Text
  ChungChi       String?               @db.VarChar(255)
  PhiGiamSat     Decimal               @default(0.00) @db.Decimal(15, 2)
  XepHang        Decimal               @default(0.00) @db.Decimal(3, 2)
  TongCongViecGS Int                   @default(0)
  TrangThai      TrangThaiDonViGiamSat @default(ChoDuyet)
  NgayDangKy     DateTime              @default(now()) @db.Timestamp(3)

  TaiKhoan TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID], onDelete: Cascade)
}

// ============ DANH MUC ============

model LoaiDichVu {
  LoaiDichVuID Int      @id @default(autoincrement())
  TenLoai      String   @db.VarChar(100)
  MoTa         String?  @db.VarChar(255)
  HinhAnh      String?  @db.VarChar(255)
  YeuCaus      YeuCau[]
}

model KyNang {
  KyNangID          Int                @id @default(autoincrement())
  TenKyNang         String             @unique @db.VarChar(100)
  MoTa              String?            @db.VarChar(255)
  YeuCauKyNangs     YeuCauKyNang[]
  FreelancerKyNangs FreelancerKyNang[]
}

model YeuCauKyNang {
  YeuCauID Int
  KyNangID Int
  YeuCau   YeuCau @relation(fields: [YeuCauID], references: [YeuCauID], onDelete: Cascade)
  KyNang   KyNang @relation(fields: [KyNangID], references: [KyNangID], onDelete: Cascade)

  @@id([YeuCauID, KyNangID])
}

model FreelancerKyNang {
  TaiKhoanID Int // TaiKhoanID cua freelancer (thay vi FreelancerID)
  KyNangID   Int
  TaiKhoan   TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID], onDelete: Cascade)
  KyNang     KyNang   @relation(fields: [KyNangID], references: [KyNangID], onDelete: Cascade)

  @@id([TaiKhoanID, KyNangID])
}

// ============ NGHIEP VU CHINH ============

model YeuCau {
  YeuCauID            Int                    @id @default(autoincrement())
  TaiKhoanID          Int // Nguoi tao yeu cau (NguoiThue)
  LoaiDichVuID        Int
  GiamSatID           Int // TaiKhoanID cua don vi giam sat
  TieuDe              String                 @db.VarChar(200)
  MoTa                String                 @db.Text
  NganSachMin         Decimal                @default(0.00) @db.Decimal(15, 2)
  NganSachMax         Decimal                @default(0.00) @db.Decimal(15, 2)
  ThoiHan             DateTime               @db.Date
  TrangThai           TrangThaiYeuCau        @default(DangNhanHoSo)
  SoLuongBaoGia       Int                    @default(0)
  YeuCauGiamSat       Boolean                @default(true)
  TrangThaiGiamSat    TrangThaiYeuCauGiamSat @default(ChoDuyet)
  LyDoTuChoiGiamSat   String?                @db.Text
  NgayGiamSatChapNhan DateTime?              @db.Timestamp(3)
  NgayTao             DateTime               @default(now()) @db.Timestamp(3)
  NgayCapNhat         DateTime               @updatedAt @db.Timestamp(3)

  NguoiTao      TaiKhoan       @relation("YeuCauNguoiTao", fields: [TaiKhoanID], references: [TaiKhoanID])
  GiamSat       TaiKhoan       @relation("YeuCauGiamSat", fields: [GiamSatID], references: [TaiKhoanID])
  LoaiDichVu    LoaiDichVu     @relation(fields: [LoaiDichVuID], references: [LoaiDichVuID])
  BaoGias       BaoGia[]
  CongViecs     CongViec[]
  YeuCauKyNangs YeuCauKyNang[]

  @@index([TaiKhoanID])
  @@index([TrangThai])
  @@index([LoaiDichVuID])
  @@index([GiamSatID])
}

model BaoGia {
  BaoGiaID         Int             @id @default(autoincrement())
  YeuCauID         Int
  TaiKhoanID       Int // TaiKhoanID cua freelancer gui bao gia
  GiaDeXuat        Decimal         @db.Decimal(15, 2)
  ThoiGianThucHien Int
  NoiDung          String?         @db.Text
  TrangThai        TrangThaiBaoGia @default(DaGui)
  NgayTao          DateTime        @default(now()) @db.Timestamp(3)
  NgayCapNhat      DateTime        @updatedAt @db.Timestamp(3)

  YeuCau     YeuCau   @relation(fields: [YeuCauID], references: [YeuCauID])
  Freelancer TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID])

  @@index([YeuCauID])
  @@index([TaiKhoanID])
}

model CongViec {
  CongViecID        Int                      @id @default(autoincrement())
  YeuCauID          Int
  FreelancerID      Int // TaiKhoanID cua freelancer
  NguoiThueID       Int // TaiKhoanID cua nguoi thue
  GiamSatID         Int // TaiKhoanID cua giam sat
  GiaThoa           Decimal                  @db.Decimal(15, 2)
  ThoiGianThoa      Int
  TrangThai         TrangThaiCongViec        @default(MoiTao)
  NgayBatDau        DateTime?                @db.Timestamp(3)
  NgayKetThuc       DateTime?                @db.Timestamp(3)
  TrangThaiGiamSat  TrangThaiGiamSatCongViec @default(ChoDuyet)
  PhiGiamSat        Decimal                  @default(0.00) @db.Decimal(15, 2)
  FreelancerXacNhan Boolean                  @default(false)
  GiamSatXacNhan    Boolean                  @default(false)
  NguoiThueXacNhan  Boolean                  @default(false)
  DaThanhToanEscrow Boolean                  @default(false)
  NgayTao           DateTime                 @default(now()) @db.Timestamp(3)

  YeuCau          YeuCau           @relation(fields: [YeuCauID], references: [YeuCauID])
  Freelancer      TaiKhoan         @relation("CongViecFreelancer", fields: [FreelancerID], references: [TaiKhoanID])
  NguoiThue       TaiKhoan         @relation("CongViecNguoiThue", fields: [NguoiThueID], references: [TaiKhoanID])
  GiamSat         TaiKhoan         @relation("CongViecGiamSat", fields: [GiamSatID], references: [TaiKhoanID])
  YeuCauGiamSats  YeuCauGiamSat[]
  TienDos         TienDo[]
  TranhChaps      TranhChap[]
  ThanhToans      ThanhToan[]
  YeuCauHoanTiens YeuCauHoanTien[]
  CuocHoiThoais   CuocHoiThoai[]
  DanhGias        DanhGia[]

  @@index([YeuCauID])
  @@index([FreelancerID])
  @@index([NguoiThueID])
  @@index([GiamSatID])
  @@index([TrangThai])
}

model YeuCauGiamSat {
  YCGiamSatID    Int                    @id @default(autoincrement())
  CongViecID     Int
  NguoiThueID    Int // TaiKhoanID
  GiamSatID      Int // TaiKhoanID
  FreelancerID   Int // TaiKhoanID
  TrangThai      TrangThaiYeuCauGiamSat @default(ChoDuyet)
  LyDoTuChoi     String?                @db.Text
  PhiGiamSatThoa Decimal                @default(0.00) @db.Decimal(15, 2)
  NgayYeuCau     DateTime               @default(now()) @db.Timestamp(3)
  NgayChapNhan   DateTime?              @db.Timestamp(3)
  NgayHoanThanh  DateTime?              @db.Timestamp(3)

  CongViec   CongViec @relation(fields: [CongViecID], references: [CongViecID])
  NguoiThue  TaiKhoan @relation("YCGSNguoiThue", fields: [NguoiThueID], references: [TaiKhoanID])
  Freelancer TaiKhoan @relation("YCGSFreelancer", fields: [FreelancerID], references: [TaiKhoanID])
  GiamSat    TaiKhoan @relation("YCGSGiamSat", fields: [GiamSatID], references: [TaiKhoanID])

  @@index([CongViecID])
}

model TienDo {
  TienDoID         Int                    @id @default(autoincrement())
  CongViecID       Int
  TaiKhoanID       Int // Freelancer tao tien do
  TieuDe           String                 @db.VarChar(200)
  MoTa             String?                @db.Text
  PhanTram         Int                    @default(0) @db.SmallInt
  TepDinhKem       String?                @db.VarChar(500)
  XacNhanBoi       Int? // TaiKhoanID cua giam sat xac nhan
  TrangThaiXacNhan TrangThaiXacNhanTienDo @default(ChuaXacNhan)
  NgayTao          DateTime               @default(now()) @db.Timestamp(3)

  CongViec CongViec @relation(fields: [CongViecID], references: [CongViecID])
  NguoiTao TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID])

  @@index([CongViecID])
  @@index([TaiKhoanID])
}

model ThanhToan {
  ThanhToanID Int                 @id @default(autoincrement())
  CongViecID  Int
  TaiKhoanID  Int // Nguoi thanh toan (NguoiThue)
  SoTien      Decimal             @db.Decimal(15, 2)
  LoaiTT      LoaiThanhToan
  PhuongThuc  PhuongThucThanhToan @default(Vi)
  TrangThai   TrangThaiThanhToan  @default(ChoXuLy)
  GhiChu      String?             @db.VarChar(255)
  NgayTao     DateTime            @default(now()) @db.Timestamp(3)

  CongViec CongViec @relation(fields: [CongViecID], references: [CongViecID])
  NguoiTra TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID])

  @@index([CongViecID])
  @@index([TaiKhoanID])
}

model YeuCauHoanTien {
  YeuCauHoanTienID Int                     @id @default(autoincrement())
  CongViecID       Int
  NguoiThueID      Int
  FreelancerID     Int
  LyDo             String                  @db.VarChar(255)
  MoTa             String?                 @db.Text
  TrangThai        TrangThaiYeuCauHoanTien @default(ChoFreelancerDuyet)
  TongEscrow       Decimal                 @db.Decimal(15, 2)
  PhiHeThong       Decimal                 @db.Decimal(15, 2)
  TienFreelancer   Decimal                 @db.Decimal(15, 2)
  TienGiamSat      Decimal                 @db.Decimal(15, 2)
  TienHoan         Decimal                 @db.Decimal(15, 2)
  TranhChapID      Int?                    @unique
  NgayTao          DateTime                @default(now()) @db.Timestamp(3)
  NgayPhanHoi      DateTime?               @db.Timestamp(3)

  CongViec          CongViec            @relation(fields: [CongViecID], references: [CongViecID])
  NguoiThue         TaiKhoan            @relation("HoanTienNguoiThue", fields: [NguoiThueID], references: [TaiKhoanID])
  Freelancer        TaiKhoan            @relation("HoanTienFreelancer", fields: [FreelancerID], references: [TaiKhoanID])
  TranhChap         TranhChap?          @relation(fields: [TranhChapID], references: [TranhChapID])
  BangChungHoanTien BangChungHoanTien[]

  @@index([CongViecID])
  @@index([NguoiThueID])
  @@index([FreelancerID])
  @@index([TrangThai])
}

model TranhChap {
  TranhChapID    Int                @id @default(autoincrement())
  CongViecID     Int
  NguoiGuiID     Int // TaiKhoanID nguoi mo tranh chap
  GiamSatID      Int // TaiKhoanID giam sat cua cong viec xu ly
  LyDo           String             @db.VarChar(255)
  MoTa           String?            @db.Text
  TrangThai      TrangThaiTranhChap @default(MoiMo)
  YeuCauHoanTien Decimal            @default(0.00) @db.Decimal(15, 2)
  NgayMo         DateTime           @default(now()) @db.Timestamp(3)
  NgayDong       DateTime?          @db.Timestamp(3)

  CongViec            CongViec             @relation(fields: [CongViecID], references: [CongViecID])
  NguoiGui            TaiKhoan             @relation(fields: [NguoiGuiID], references: [TaiKhoanID])
  BangChungTranhChaps BangChungTranhChap[]
  KetLuanTranhChap    KetLuanTranhChap?
  YeuCauHoanTienNguon YeuCauHoanTien?

  @@index([CongViecID])
  @@index([NguoiGuiID])
}

model BangChungTranhChap {
  BangChungID   Int           @id @default(autoincrement())
  TranhChapID   Int
  NguoiNopID    Int // TaiKhoanID
  LoaiBangChung LoaiBangChung @default(GhiChu)
  NoiDung       String?       @db.Text
  DuongDanFile  String?       @db.VarChar(500)
  NgayNop       DateTime      @default(now()) @db.Timestamp(3)

  TranhChap TranhChap @relation(fields: [TranhChapID], references: [TranhChapID])
  NguoiNop  TaiKhoan  @relation(fields: [NguoiNopID], references: [TaiKhoanID])

  @@index([TranhChapID])
  @@index([NguoiNopID])
}

model KetLuanTranhChap {
  KetLuanID        Int               @id @default(autoincrement())
  TranhChapID      Int               @unique
  GiamSatID        Int // TaiKhoanID giam sat ket luan
  KetQua           KetQuaTranhChap
  LyDo             String            @db.Text
  SoTienHoan       Decimal           @default(0.00) @db.Decimal(15, 2)
  SoTienFreelancer Decimal           @default(0.00) @db.Decimal(15, 2)
  SoTienGiamSat    Decimal           @default(0.00) @db.Decimal(15, 2)
  SoTienHeThong    Decimal           @default(0.00) @db.Decimal(15, 2)
  BenChiuPhi       BenChiuPhiKetLuan @default(ChiaSe)
  NgayKetLuan      DateTime          @default(now()) @db.Timestamp(3)

  TranhChap        TranhChap          @relation(fields: [TranhChapID], references: [TranhChapID])
  BangChungKetLuan BangChungKetLuan[]
}

model BangChungHoanTien {
  BangChungID      Int              @id @default(autoincrement())
  YeuCauHoanTienID Int
  NguoiNopID       Int // TaiKhoanID
  LoaiBangChung    LoaiBangChung    @default(GhiChu)
  NoiDung          String?          @db.Text
  DuongDanFile     String?          @db.VarChar(500)
  LoaiNguoiNop     String           @db.VarChar(50) // "NguoiThue" | "Freelancer"
  NgayNop          DateTime         @default(now()) @db.Timestamp(3)

  YeuCauHoanTien YeuCauHoanTien @relation(fields: [YeuCauHoanTienID], references: [YeuCauHoanTienID], onDelete: Cascade)
  NguoiNop       TaiKhoan       @relation(fields: [NguoiNopID], references: [TaiKhoanID])

  @@index([YeuCauHoanTienID])
  @@index([NguoiNopID])
}

model BangChungKetLuan {
  BangChungID   Int           @id @default(autoincrement())
  KetLuanID     Int
  NguoiNopID    Int // TaiKhoanID (GiamSatID)
  LoaiBangChung LoaiBangChung @default(GhiChu)
  NoiDung       String?       @db.Text
  DuongDanFile  String?       @db.VarChar(500)
  NgayNop       DateTime      @default(now()) @db.Timestamp(3)

  KetLuan  KetLuanTranhChap @relation(fields: [KetLuanID], references: [KetLuanID], onDelete: Cascade)
  NguoiNop TaiKhoan         @relation(fields: [NguoiNopID], references: [TaiKhoanID])

  @@index([KetLuanID])
  @@index([NguoiNopID])
}

model CuocHoiThoai {
  CuocHoiThoaiID Int                   @id @default(autoincrement())
  CongViecID     Int?
  ThanhVien1ID   Int // TaiKhoanID
  ThanhVien2ID   Int // TaiKhoanID
  TinNhanCuoi    DateTime?             @db.Timestamp(3)
  TrangThai      TrangThaiCuocHoiThoai @default(DangMo)
  NgayTao        DateTime              @default(now()) @db.Timestamp(3)

  CongViec   CongViec? @relation(fields: [CongViecID], references: [CongViecID], onDelete: SetNull)
  ThanhVien1 TaiKhoan  @relation("ChatThanhVien1", fields: [ThanhVien1ID], references: [TaiKhoanID])
  ThanhVien2 TaiKhoan  @relation("ChatThanhVien2", fields: [ThanhVien2ID], references: [TaiKhoanID])
  TinNhans   TinNhan[]

  @@index([CongViecID])
  @@index([ThanhVien1ID])
  @@index([ThanhVien2ID])
}

model TinNhan {
  TinNhanID      Int         @id @default(autoincrement())
  CuocHoiThoaiID Int
  NguoiGuiID     Int // TaiKhoanID
  NoiDung        String      @db.Text
  LoaiTin        LoaiTinNhan @default(VanBan)
  DaDoc          Boolean     @default(false)
  NgayTao        DateTime    @default(now()) @db.Timestamp(3)

  CuocHoiThoai CuocHoiThoai @relation(fields: [CuocHoiThoaiID], references: [CuocHoiThoaiID])
  NguoiGui     TaiKhoan     @relation(fields: [NguoiGuiID], references: [TaiKhoanID])

  @@index([CuocHoiThoaiID])
  @@index([NguoiGuiID])
}

model DanhGia {
  DanhGiaID      Int         @id @default(autoincrement())
  CongViecID     Int
  NguoiDanhGiaID Int // TaiKhoanID
  NguoiDuocDGID  Int // TaiKhoanID
  DiemSo         Int         @db.SmallInt
  BinhLuan       String?     @db.Text
  LoaiDanhGia    LoaiDanhGia
  NgayTao        DateTime    @default(now()) @db.Timestamp(3)

  CongViec     CongViec @relation(fields: [CongViecID], references: [CongViecID])
  NguoiDanhGia TaiKhoan @relation("DanhGiaNguoiGui", fields: [NguoiDanhGiaID], references: [TaiKhoanID])
  NguoiDuocDG  TaiKhoan @relation("DanhGiaNguoiNhan", fields: [NguoiDuocDGID], references: [TaiKhoanID])

  @@index([CongViecID])
  @@index([NguoiDanhGiaID])
  @@index([NguoiDuocDGID])
}

model ThongBao {
  ThongBaoID   Int          @id @default(autoincrement())
  TaiKhoanID   Int // Nguoi nhan thong bao
  TieuDe       String       @db.VarChar(200)
  NoiDung      String?      @db.Text
  LoaiThongBao LoaiThongBao @default(HeThong)
  DaDoc        Boolean      @default(false)
  NgayTao      DateTime     @default(now()) @db.Timestamp(3)

  TaiKhoan TaiKhoan @relation(fields: [TaiKhoanID], references: [TaiKhoanID])

  @@index([TaiKhoanID, DaDoc])
}

model BaoCao {
  BaoCaoID      Int             @id @default(autoincrement())
  NguoiBaoCaoID Int // TaiKhoanID
  NguoiBiCaoID  Int // TaiKhoanID
  LyDo          String          @db.VarChar(255)
  MoTa          String?         @db.Text
  TrangThai     TrangThaiBaoCao @default(ChoXuLy)
  KetQua        String?         @db.Text
  AdminXuLyID   Int? // TaiKhoanID admin
  NgayTao       DateTime        @default(now()) @db.Timestamp(3)
  NgayXuLy      DateTime?       @db.Timestamp(3)

  NguoiBaoCao TaiKhoan  @relation("BaoCaoNguoiGui", fields: [NguoiBaoCaoID], references: [TaiKhoanID])
  NguoiBiCao  TaiKhoan  @relation("BaoCaoNguoiNhan", fields: [NguoiBiCaoID], references: [TaiKhoanID])
  AdminXuLy   TaiKhoan? @relation("BaoCaoAdmin", fields: [AdminXuLyID], references: [TaiKhoanID])

  @@index([NguoiBaoCaoID])
  @@index([NguoiBiCaoID])
}

model KhuyenMai {
  KhuyenMaiID Int                @id @default(autoincrement())
  MaCode      String             @unique @db.VarChar(50)
  LoaiGiam    LoaiGiamKhuyenMai
  GiaTriGiam  Decimal            @db.Decimal(15, 2)
  GiaTriToiDa Decimal?           @db.Decimal(15, 2)
  SoLuotDung  Int                @default(0)
  GioiHanLuot Int?
  TrangThai   TrangThaiKhuyenMai @default(HoatDong)
  NgayBatDau  DateTime           @db.Timestamp(3)
  NgayKetThuc DateTime           @db.Timestamp(3)
}
